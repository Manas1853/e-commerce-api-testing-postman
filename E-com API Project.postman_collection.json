									"let response = pm.response.json();\r",
									"\r",
									"pm.test(\"Status code is 200\", () => {\r",
									"    pm.response.to.have.status(200);\r",
									"});\r",
									"\r",
									"pm.test(\"Access token exists\", () => {\r",
									"    pm.expect(response.accessToken).to.exist;\r",
									"});\r",
									"\r",
									"pm.test(\"User ID exists\", () => {\r",
									"    pm.expect(response.id).to.exist;\r",
									"});\r",
									"\r",
									"pm.test(\"Username exists\", () => {\r",
									"    pm.expect(response.username).to.exist;\r",
									"});\r",
